<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <connectionStrings>
    <!-- Update Server/Database to match your SQL Server instance -->
	  <add name="FileIODB"
	   connectionString="Data Source=(LocalDB)\MSSQLLocalDB;Initial Catalog=FileIODB;Integrated Security=True;AttachDbFilename="
	   providerName="System.Data.SqlClient" />
  </connectionStrings>

  <appSettings>
    <add key="UploadFolder" value="~/Uploads/" />
    <add key="MaxFileSizeMB" value="50" />
  </appSettings>

  <system.web>
    <compilation debug="true" targetFramework="4.7.2" />
    <httpRuntime targetFramework="4.7.2" maxRequestLength="51200" />
    <pages>
      <namespaces>
        <add namespace="System.Data" />
        <add namespace="System.Data.SqlClient" />
      </namespaces>
    </pages>
  </system.web>

  <system.webServer>
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="52428800" />
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
